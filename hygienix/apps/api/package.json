{
  "name": "@hygienix/api",
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "db:generate": "cd ../../packages/database && npm run db:generate",
    "db:migrate": "cd ../../packages/database && npm run db:migrate",
    "db:seed": "cd ../../packages/database && npm run db:seed"
  },
  "dependencies": {
    "@hygienix/database": "*",
    "@hygienix/types": "*",
    "@hygienix/validators": "*",
    "express": "^4.19.0",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "express-rate-limit": "^7.3.0",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "zod": "^3.23.0",
    "multer": "^1.4.5-lts.1",
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "resend": "^3.2.0",
    "puppeteer": "^22.12.0",
    "handlebars": "^4.7.8",
    "pino": "^9.2.0",
    "pino-pretty": "^11.2.0",
    "uuid": "^10.0.0",
    "date-fns": "^3.6.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/compression": "^1.7.5",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/bcryptjs": "^2.4.6",
    "@types/multer": "^1.4.11",
    "@types/uuid": "^10.0.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "ts-node-dev": "^2.0.0"
  }
}
