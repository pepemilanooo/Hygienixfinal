{
  "expo": {
    "name": "Hygienix",
    "slug": "hygienix",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A6B3C"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hygienix.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Hygienix usa la fotocamera per scattare foto durante gli interventi.",
        "NSPhotoLibraryUsageDescription": "Hygienix accede alla galleria per allegare foto agli interventi.",
        "NSLocationWhenInUseUsageDescription": "Hygienix usa la posizione per registrare il check-in al luogo dell'intervento."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1A6B3C"
      },
      "package": "com.hygienix.app",
      "permissions": ["CAMERA", "READ_EXTERNAL_STORAGE", "WRITE_EXTERNAL_STORAGE", "ACCESS_FINE_LOCATION"]
    },
    "plugins": ["expo-router", "expo-secure-store", "expo-camera", "expo-image-picker", "expo-location", "expo-notifications"],
    "scheme": "hygienix",
    "web": { "bundler": "metro" },
    "extra": {
      "apiUrl": "http://localhost:4000/api/v1",
      "eas": { "projectId": "your-eas-project-id" }
    }
  }
}
